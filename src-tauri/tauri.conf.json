{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "suvidhaAI",
	"version": "1.3.0",
	"identifier": "com.suvidhaai.connector",
	"build": {
		"frontendDist": "../src"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "suvidhaAI",
				"url": "index.html",
				"width": 1280,
				"height": 800,
				"minWidth": 1100,
				"minHeight": 650,
				"devtools": true,
				"resizable": true
			}
		],
		"security": {
			"csp": null,
			"dangerousDisableAssetCspModification": true
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"createUpdaterArtifacts": true
	},
	"plugins": {
		"updater": {
			"pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQwQ0ZDMjI2Qjc1Rjc1QzcKUldUSGRWKzNKc0xQME02RXNKUnRLU0VSWEs2cTkySGtTd0ptQ2FuV0hIRkY0dndGSnpkWnp6T2UK",
			"endpoints": [
				"https://github.com/teamsuvidhaai/tallyconnector/releases/latest/download/latest.json"
			]
		}
	}
}