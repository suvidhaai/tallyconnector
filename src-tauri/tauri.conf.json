{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "ComplianceAI Expert",
	"version": "0.1.0",
	"identifier": "com.complianceai.expert",
	"build": {
		"frontendDist": "../src"
	},
	"app": {
		"withGlobalTauri": true,
		"windows": [
			{
				"title": "ComplianceAI Expert",
				"url": "index.html",
				"width": 1280,
				"height": 800,
				"minWidth": 1100,
				"minHeight": 650,
				"devtools": true,
				"resizable": true
			}
		],
		"security": {
			"csp": null,
			"dangerousDisableAssetCspModification": true
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}